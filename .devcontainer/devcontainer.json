{
  "name": "svelte-ui-template",
  "dockerComposeFile": "../compose.dev.yaml",
  "service": "app",
  "workspaceFolder": "/app",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": ["svelte.svelte-vscode", "esbenp.prettier-vscode", "dbaeumer.vscode-eslint"],
      "settings": {
        "typescript.preferences.tsdk": "/app/node_modules/typescript/lib",
        "eslint.workingDirectories": ["/app"],
        "prettier.prettierPath": "/app/node_modules/.bin/prettier",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[svelte]": {
          "editor.defaultFormatter": "svelte.svelte-vscode"
        }
      }
    }
  }
}
