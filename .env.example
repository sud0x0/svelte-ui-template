# Copy to .env and fill in values. Never commit .env.
# Only VITE_-prefixed, NON-SECRET config reaches the browser bundle. The future
# OIDC client secret lives only in the Go BFF, never here. (.claude/rules/security.md)

# ---------------------------------------------------------------------------
# VITE_API_TARGET — backend the Vite dev proxy forwards /api, /auth and /health
# to. The browser always uses same-origin relative paths; this is dev-only.
#   - Running in a container: http://host.containers.internal:8080
#   - Running locally (no container): http://localhost:8080
# ---------------------------------------------------------------------------
VITE_API_TARGET=http://host.containers.internal:8080

# ---------------------------------------------------------------------------
# VITE_AUTH_MODE — the auth switch. The whole template flips on this flag.
#   disabled (default) — no auth. getCurrentUser() resolves a static local dev
#                        user so guarded views render; login/logout are no-ops.
#   bff                — Backend-For-Frontend. The Go API performs OIDC and holds
#                        all tokens; the SPA holds none. Flipping this plus
#                        filling the // TODO(auth) stubs is the entire change.
# Authentication is intentionally NOT implemented — see README "Authentication".
# ---------------------------------------------------------------------------
VITE_AUTH_MODE=disabled
