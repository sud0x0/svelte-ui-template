# Copy to .env and fill in values. Never commit .env.
# Only VITE_-prefixed, NON-SECRET config reaches the browser bundle. The future
# OIDC client secret lives only in the Go BFF, never here. (.claude/rules/security.md)

# ---------------------------------------------------------------------------
# VITE_API_TARGET — backend the Vite dev proxy forwards /api, /auth and /health
# to. The browser always uses same-origin relative paths; this is dev-only.
#   - Running in a container: http://host.containers.internal:8080
#   - Running locally (no container): http://localhost:8080
# ---------------------------------------------------------------------------
VITE_API_TARGET=http://host.containers.internal:8080

# ---------------------------------------------------------------------------
# VITE_AUTH_MODE — the auth switch. The whole template flips on this flag.
#   disabled (default) — no auth. getCurrentUser() resolves a static local dev
#                        user so guarded views render; login/logout are no-ops.
#   bff                — Backend-For-Frontend. The Go API performs OIDC and holds
#                        all tokens; the SPA holds none. Flipping this plus
#                        filling the // TODO(auth) stubs is the entire change.
# In `bff` mode, point VITE_API_TARGET at the BFF (below), not the Go API:
# the SPA talks only to the BFF, which owns the tokens and proxies to the Go API.
#   In-compose: http://bff:8081   Bare-metal: http://localhost:8081
# ---------------------------------------------------------------------------
VITE_AUTH_MODE=disabled

# ===========================================================================
# BFF (Backend-for-Frontend) — only needed when VITE_AUTH_MODE=bff.
# ===========================================================================
# The BFF is the confidential OIDC client: it holds ALL tokens server-side,
# gives the browser only a __Host- session cookie, and proxies /api/* to the Go
# API with the bearer attached. These vars are read ONLY by the BFF process
# (bff/src/config.ts) — none are VITE_-prefixed, so none reach the browser
# bundle. The client secret and cookie secret live here and nowhere else.

# Public origin the browser reaches the BFF on. The OIDC redirect_uri is derived
# as <origin>/auth/callback — register EXACTLY that at your IdP.
BFF_PUBLIC_ORIGIN=http://localhost:8081

# OIDC issuer (discovery at <issuer>/.well-known/openid-configuration). Must
# match the `iss` your IdP mints, and the Go API's OIDC_ISSUER_URL.
BFF_ISSUER_URL=https://idp.example.com

# Confidential-client credentials from your IdP. The BFF is a confidential client
# (draft-ietf-oauth-browser-based-apps §6.1.3.1) — the secret NEVER leaves the server.
BFF_CLIENT_ID=svelte-ui-bff
BFF_CLIENT_SECRET=change-me-confidential-client-secret

# The Go API the BFF proxies to (the SPA never talks to it directly in bff mode).
#   In a container: http://host.containers.internal:8080
#   Bare-metal:     http://localhost:8080
BFF_API_UPSTREAM=http://localhost:8080

# HMAC key for the signed double-submit CSRF token (security.md rule 2). MUST be
# at least 32 bytes of high-entropy random. Generate: openssl rand -base64 32
BFF_COOKIE_SECRET=change-me-at-least-32-bytes-of-random-secret

# OIDC scopes. Defaults to "openid profile email" if unset.
BFF_SCOPES=openid profile email

# Listen port (default 8081).
BFF_PORT=8081
