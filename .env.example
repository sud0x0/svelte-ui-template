# Copy to .env and fill in values. Never commit .env.
# Only VITE_-prefixed, NON-SECRET config reaches the browser bundle. The future
# OIDC client secret lives only in the Go BFF, never here. (.claude/rules/security.md)

# ---------------------------------------------------------------------------
# VITE_API_TARGET — backend the Vite dev proxy forwards /api, /auth and /health
# to. The browser always uses same-origin relative paths; this is dev-only.
#   - Running in a container: http://host.containers.internal:8080
#   - Running locally (no container): http://localhost:8080
# ---------------------------------------------------------------------------
VITE_API_TARGET=http://host.containers.internal:8080

# ---------------------------------------------------------------------------
# VITE_AUTH_MODE — the auth switch. The whole template flips on this flag.
#   disabled (default) — no auth. getCurrentUser() resolves a static local dev
#                        user so guarded views render; login/logout are no-ops.
#   bff                — Backend-for-Frontend. The BFF (bff/) is the confidential
#                        OIDC client and holds all tokens. The SPA holds none. In
#                        `bff` mode the flow is live and end-to-end tested.
# In `bff` mode, point VITE_API_TARGET at the BFF (below), not the Go API:
# the SPA talks only to the BFF, which owns the tokens and proxies to the Go API.
#   In-compose: http://bff:8081   Bare-metal: http://localhost:8081
# ---------------------------------------------------------------------------
VITE_AUTH_MODE=disabled

# ===========================================================================
# BFF (Backend-for-Frontend) — only needed when VITE_AUTH_MODE=bff.
# ===========================================================================
# The BFF is the confidential OIDC client: it holds ALL tokens server-side,
# gives the browser only a __Host- session cookie, and proxies /api/* to the Go
# API with the bearer attached. These vars are read ONLY by the BFF process
# (bff/src/config.ts) — none are VITE_-prefixed, so none reach the browser
# bundle. The client secret and cookie secret live here and nowhere else.

# Public origin the browser reaches the BFF on — i.e. the UI origin, NOT the BFF's
# own listen port. In EVERY documented topology the browser talks to the BFF
# THROUGH the UI origin: in dev, Vite (:3000) proxies /auth,/api,/health to the
# BFF; in prod, Caddy proxies the site origin to the BFF. The OIDC redirect_uri is
# derived as <origin>/auth/callback and the __Host- cookies are scoped to this
# origin, so it MUST be the UI origin (http://localhost:3000 for the dev stack),
# never http://localhost:8081. Register EXACTLY <origin>/auth/callback at your IdP.
BFF_PUBLIC_ORIGIN=http://localhost:3000

# OIDC issuer (discovery at <issuer>/.well-known/openid-configuration). Must
# match the `iss` your IdP mints, and the Go API's OIDC_ISSUER_URL. MUST be
# https:// except for a loopback host (see BFF_DEV_INSECURE below).
BFF_ISSUER_URL=https://idp.example.com

# Confidential-client credentials from your IdP. The BFF is a confidential client
# (draft-ietf-oauth-browser-based-apps §6.1.3.1) — the secret NEVER leaves the server.
BFF_CLIENT_ID=svelte-ui-bff
BFF_CLIENT_SECRET=change-me-confidential-client-secret

# The Go API the BFF proxies to (the SPA never talks to it directly in bff mode).
#   In a container: http://host.containers.internal:8080
#   Bare-metal:     http://localhost:8080
BFF_API_UPSTREAM=http://localhost:8080

# Timeout for a proxied upstream (Go API) call, in milliseconds. Bounds a hung
# upstream so it cannot pin a BFF connection until the OS socket timeout. Must be
# an integer in (0, 60000]. Default 10000 (10s).
BFF_API_TIMEOUT_MS=10000

# Timeout for the BFF's OWN calls to the IdP (OIDC discovery / token / refresh),
# in milliseconds, integer in (0, 60000], default 10000. Bounds a hung IdP so it
# cannot pin /auth/callback or stall the single-flight refresh queue (fix 9).
BFF_OIDC_TIMEOUT_MS=10000

# Set to "true" ONLY when the BFF runs behind a TRUSTED reverse proxy (e.g. Caddy)
# that sets X-Forwarded-For to the real client IP. The BFF then PRESERVES the
# inbound XFF (appending its own peer) so the Go API sees the real client for
# per-IP audit/limiting. Leave unset for a directly-exposed BFF, which trusts only
# its immediate peer. Default false (fix 11).
# BFF_TRUSTED_PROXY=true

# HMAC key for the signed double-submit CSRF token (security.md rule 2). MUST be
# at least 32 bytes of high-entropy random. Generate: openssl rand -base64 32
BFF_COOKIE_SECRET=change-me-at-least-32-bytes-of-random-secret

# OIDC scopes. Defaults to "openid profile email" if unset.
BFF_SCOPES=openid profile email

# OPTIONAL access-token audience. When set, the BFF sends it as the `audience`
# request parameter on the authorization request and the token + refresh grants,
# so the IdP mints an access token whose `aud` the Go API accepts (the Go API
# 401s any bearer whose `aud` != its OIDC_AUDIENCE). MUST equal the Go API's
# OIDC_AUDIENCE. Leave UNSET if your IdP configures JWT access tokens + audience
# server-side instead. Unset by default.
# BFF_AUDIENCE=https://go-api.example.com

# DEV ONLY. Allow a NON-loopback http:// BFF_ISSUER_URL / BFF_API_UPSTREAM. By
# default the BFF fails fast on a plain-http issuer/upstream unless the host is
# loopback (localhost, 127.0.0.0/8, ::1, *.localhost), because those endpoints
# carry the client secret and tokens and http would silently disable TLS. Set to
# the exact string "true" ONLY for local development against a non-loopback http
# service. NEVER set in production.
# BFF_DEV_INSECURE=true

# Listen port (default 8081).
BFF_PORT=8081
