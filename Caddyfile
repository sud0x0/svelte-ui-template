# svelte-ui-template — Caddyfile
#
# Reference production host. Ships in the release tarball alongside the static
# bundle (flat layout: this file sits next to index.html / assets/). Caddy
# provisions and renews TLS via Let's Encrypt automatically as long as
# SITE_ADDRESS resolves to this host on ports 80 + 443.
#
# Usage:
#   tar -xzf svelte-ui-template-<version>.tar.gz -C /var/www/app --strip-components=1
#   cd /var/www/app
#   export SITE_ADDRESS=app.example.com API_UPSTREAM=api.internal:8080 ACME_EMAIL=ops@example.com
#   caddy run --config Caddyfile
#
# Env vars:
#   SITE_ADDRESS — hostname clients reach this UI on (real DNS name for ACME).
#   API_UPSTREAM — host:port of the Go API / BFF backend.
#   SITE_ROOT    — document root. Defaults to "." (this directory). Use ./dist
#                  when testing from the source tree.
#   ACME_EMAIL   — contact email for the Let's Encrypt account.
#
# Homeserver / LAN-only (.local hostnames, IP-only, or any host Let's Encrypt
# can't reach on :80): replace the `tls { … }` block with `tls internal` and
# delete the `http://{$SITE_ADDRESS}` redirect block. Run `caddy trust` on each
# client to install the local root. See the README "Releases" section.
{
	email {$ACME_EMAIL}
	servers {
		protocols h1 h2 h3
	}
}

# Explicit HTTP listener that 308-redirects everything to HTTPS.
http://{$SITE_ADDRESS} {
	redir https://{host}{uri} permanent
}

{$SITE_ADDRESS} {
	root * {$SITE_ROOT:.}
	encode zstd gzip

	tls {
		protocols tls1.2 tls1.3
	}

	# Security headers at the edge. The CSP here is authoritative — and unlike
	# the <meta> tag in index.html it can express frame-ancestors. Keep the two
	# in sync. script-src is strict ('self', no unsafe-inline/eval); style-src
	# carries the documented 'unsafe-inline' compromise for Vite's runtime CSS
	# injection. See .claude/rules/security.md and decisions.md.
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
		# HSTS without `preload`: preload is a deliberate operator opt-in, not a
		# safe default. It requires submitting this domain to the browser preload
		# list (hstspreload.org), forces HTTPS on EVERY subdomain, and is slow and
		# hard to reverse (removal can take months to propagate). An operator who
		# owns the whole domain tree can append `; preload`.
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		Cross-Origin-Opener-Policy "same-origin"
		# Don't leak the Caddy version.
		-Server
	}

	# Reverse-proxy the API, auth, and health surfaces to the backend so the SPA
	# stays same-origin (enables SameSite=Strict session cookies, no CORS).
	#
	# What {$API_UPSTREAM} points at depends on the auth mode:
	#   disabled — the Go API directly (Browser -> Caddy -> Go API).
	#   bff      — the BFF (Browser -> Caddy -> BFF -> Go API). The BFF is the
	#              confidential OIDC client; it terminates /auth/*, owns the
	#              __Host- session cookie, and attaches the bearer to /api/*.
	#
	# Either way the CSP above is UNCHANGED, and connect-src 'self' still holds.
	# This is the headline security win of the BFF architecture: the browser only
	# ever talks to THIS origin (fetch stays same-origin) and the IdP round trip is
	# a top-level navigation, not a connect-src fetch — so no IdP origin, no token
	# endpoint, and no CORS ever need to appear in the policy.
	#
	# PRODUCTION HARDENING (item 6): put a PER-IP RATE LIMIT in front of
	# /auth/login. Each hit creates a short-lived server-side login transaction in
	# the BFF; the store is capped and REJECTS at capacity (bff/src/session.ts) so a
	# flood cannot evict a legitimate in-flight login, but a rate limit keeps the
	# cap from ever being approached. Standard Caddy has NO built-in rate_limit —
	# use the `caddy-ratelimit` plugin (a custom build) or an upstream WAF / load
	# balancer. Example with the plugin:
	#     @login path /auth/login
	#     rate_limit @login {
	#         zone login { key {remote_host}  events 10  window 1m }
	#     }
	@backend path /api/* /auth/* /health
	handle @backend {
		reverse_proxy {$API_UPSTREAM} {
			# These header_up directives are set EXPLICITLY on purpose, even though
			# Caddy already populates X-Forwarded-For / X-Forwarded-Proto by default
			# (so `caddy validate` may warn they are "unnecessary" — that warning is
			# expected and accepted). Setting them to the un-spoofable connection
			# values OVERWRITES anything the client sent: Caddy's default XFF APPENDS
			# the peer to an inbound X-Forwarded-For, so without this a client could
			# inject a forged `X-Forwarded-For: 1.2.3.4` the backend would then trust
			# for per-IP rate-limiting / audit. {remote_host} is the real immediate
			# client, {scheme} the real edge scheme. Defence in depth alongside the
			# BFF's own XFF handling (bff/src/proxy.ts). Keep them explicit.
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Long-lived, immutable caching ONLY for fingerprinted Vite output. Vite
	# writes every content-hashed asset under /assets/, so a changed file gets a
	# new filename — safe to cache for a year. Matching by /assets/* (not by
	# extension) keeps non-fingerprinted root files (favicon.svg, icons.svg) OUT
	# of the immutable bucket, where a year-long stale copy would be a bug.
	@assets path /assets/*
	handle @assets {
		header Cache-Control "public, max-age=31536000, immutable"
		file_server {
			hide Caddyfile
		}
	}

	# Non-fingerprinted static files at the document root (favicon.svg,
	# icons.svg, …). Their names are STABLE, so a replaced file must be
	# revalidated — cache briefly with must-revalidate, never immutable.
	# index.html is deliberately excluded (.html is not listed): it falls through
	# to the no-store SPA handler below so a new deploy is seen at once.
	@rootstatic path *.svg *.ico *.png *.webp *.gif *.woff *.woff2 *.json *.txt *.webmanifest
	handle @rootstatic {
		header Cache-Control "public, max-age=3600, must-revalidate"
		file_server {
			hide Caddyfile
		}
	}

	# SPA fallback — index.html and anything that isn't a real file serves
	# index.html so deep links and client-side routes resolve. no-store keeps the
	# HTML shell (and its asset references) fresh on every deploy.
	handle {
		header Cache-Control "no-store, no-cache, must-revalidate"
		try_files {path} /index.html
		file_server {
			hide Caddyfile
		}
	}
}
