# ============================================================================
# THIS IS FOR LOCAL DEVELOPMENT ONLY
# ============================================================================
# Pinned to Node 22 LTS so the container matches the CI/runtime baseline
# regardless of the host's Node version.

# Base image pinned by digest for reproducible builds; the comment below names
# the tag the digest resolved from. Refresh the digest and tag together.
# (A Dockerfile FROM line can't carry an inline comment.)
# tag: node:22-alpine
FROM node:22-alpine@sha256:16e22a550f3863206a3f701448c45f7912c6896a62de43add43bb9c86130c3e2

# pnpm pinned to an exact version — keep in sync with package.json packageManager.
RUN npm install -g pnpm@10.33.2

WORKDIR /app

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

EXPOSE 3000

CMD ["pnpm", "dev", "--host", "0.0.0.0"]
