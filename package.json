{
  "name": "svelte-ui-template",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Production-ready Svelte 5 (runes) SPA template with a token-free OIDC/BFF auth seam — front-end counterpart to go-api-template.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json && tsc -p tsconfig.e2e.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "size": "node scripts/check-bundle-size.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "msw": "^2.14.6",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1"
  },
  "msw": {
    "workerDirectory": [
      "tests/public"
    ]
  },
  "packageManager": "pnpm@10.33.2"
}
