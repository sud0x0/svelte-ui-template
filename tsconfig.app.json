{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": ["svelte", "vite/client"],
    "noEmit": true,

    /* Strictness — the template is strict-by-default. */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    // Parity with tsconfig.node.json. `verbatimModuleSyntax` is already inherited
    // from the @tsconfig/svelte base (Svelte preprocess needs `import type`);
    // `noUncheckedSideEffectImports` is not in that base, so set it here to flag a
    // side-effect import of a non-existent module.
    "noUncheckedSideEffectImports": true,

    /* Type-check JS in `.svelte`/`.js` files. */
    "allowJs": true,
    "checkJs": true,
    "moduleDetection": "force"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    "tests/**/*.ts",
    "tests/**/*.svelte"
  ],
  "exclude": ["tests/e2e/**"]
}
